# nyc test coverage
.nyc_output

# Playwright test artifacts
playwright-report/
test-results/

# Uploads and test files
server/uploads/
server/data/*.json
!server/data/conditions.json
!server/data/projects.json
!server/data/files.json

# Temporary files
*.tmp
*.temp
temp/
.vercel

# Large model files (use Git LFS or external storage)
server/models/*.pth
server/models/*.pt
server/models/*.ckpt

# Local training datasets and large assets (kept out of git history)
Cubicasa5k/
server/data/

# Python virtual environment
server/venv/
venv/
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
