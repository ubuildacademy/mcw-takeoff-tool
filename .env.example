# Supabase Configuration
# Get these values from your Supabase dashboard: Settings > API
# IMPORTANT: SUPABASE_URL and VITE_SUPABASE_URL must be the same project URL,
# or the backend will return 401 when verifying the frontend's auth token.
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Frontend environment variables (for Vite) - same project as SUPABASE_URL above
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Optional: override API base URL (defaults to /api in dev via Vite proxy, /api in prod)
# VITE_API_BASE_URL=http://localhost:4000/api

# Optional: set to "false" to hide Auto-hyperlink controls in Tools
# VITE_BATCH_HYPERLINK=true

# Optional: Ollama Cloud API key for client-side model listing (admin panel; see server README)

# Server Configuration
PORT=4000

# Ollama Cloud API (server only) - required for AI Chat. Get key from https://ollama.com
# Set this in server/.env as OLLAMA_API_KEY=your_key
# OLLAMA_API_KEY=
